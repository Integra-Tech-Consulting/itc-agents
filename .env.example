# ─── OpenJarvis (already present on this LXC) ────────────────────────
JARVIS_URL=http://127.0.0.1:5055
JARVIS_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# ─── ITC agents Postgres + pgvector ──────────────────────────────────
DATABASE_URL=postgresql://itc_agents:CHANGE_ME@127.0.0.1:5432/itc_agents

# ─── Tool credentials (REAL, no mocks) ───────────────────────────────
# Any tool whose credential is missing raises ToolCredentialError at runtime.
# Fill these only with tokens scoped to the least privilege required.
HUBSPOT_API_KEY=
STRIPE_API_KEY=
STRIPE_API_KEY_MODE=test
LINEAR_API_KEY=
# Gmail outbound OAuth (auto-loaded from ~/.openjarvis/connectors/gmail.json if
# the Jarvis OAuth flow was completed with the gmail.send scope; otherwise
# fill these three env vars manually).
GMAIL_OAUTH_REFRESH_TOKEN=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# PayPal LIVE (set MODE=sandbox to point at the sandbox API base instead).
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=live
PAYPAL_API_BASE=https://api-m.paypal.com
GITHUB_BOT_TOKEN=
SLACK_BOT_TOKEN=
# Optional: enables semantic memory_retrieve via text-embedding-3-small.
# If unset, memory tools degrade to ILIKE substring search (still functional).
OPENAI_API_KEY=

# ─── Safety ──────────────────────────────────────────────────────────
ITC_AGENTS_DISABLED=false
ITC_DAILY_BUDGET_USD=5
ITC_REQUIRE_HUMAN_APPROVAL=true
